---
// Allscale Checkout for WordPress — landing page
// Design handoff: 2026-05 WordPress Landing Page / Allscale Checkout for WordPress.html
---
<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<title>Allscale Checkout for WordPress — Accept crypto on WordPress</title>
<meta name="description" content="Drop-in WooCommerce plugin. Accept USDT directly to your wallet at 0.6% per transaction. Non-custodial, on-chain, instant settlement across six EVM networks." />
<link rel="icon" href="/allscale-logo.png" type="image/png" />
<meta property="og:title" content="Allscale Checkout for WordPress" />
<meta property="og:description" content="Accept crypto on WordPress. Paid directly to your wallet. 0.6% fees. Instant USDT settlement." />
<meta property="og:url" content="https://labs.allscale.io/wordpress" />
<meta property="og:type" content="website" />

<style is:global>
  /* ─────────────────────────────────────────────────────────────
     AllScale Design System — colors & type
     ───────────────────────────────────────────────────────────── */

  @import url('https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&display=swap');

  @font-face {
    font-family: 'Archivo';
    font-style: normal;
    font-weight: 100 900;
    font-stretch: 62.5% 125%;
    font-display: swap;
    src: url('/fonts/Archivo-VariableFont.ttf') format('truetype-variations'),
         url('/fonts/Archivo-VariableFont.ttf') format('truetype');
  }

  :root {
    --bg:           #FDFFFE;
    --bg-white:     #FFFFFF;
    --surface:      #FAFBFA;
    --surface2:     #F2F8F5;
    --surface3:     #E5EEEA;

    --border:       #E5EEEA;
    --border-gray:  #E4E4E4;
    --border2:      #C5DDD4;

    --text:         #0C3124;
    --text2:        #83968F;
    --text3:        #B0C4BB;
    --text-dark:    #0D0D0D;

    --accent:       #009859;
    --accent-hover: #0CAA67;
    --accent2:      #087E4C;
    --accent-glow:  #F2F8F5;
    --accent-light: #E5FAF1;
    --brand-light:  #12D16B;

    --shadow:       0 8px 40px rgba(0,0,0,0.10);
    --shadow-md:    0 4px 24px rgba(0,0,0,0.08);

    --font-sans:    'Archivo', system-ui, -apple-system, sans-serif;
    --font-mono:    'DM Mono', ui-monospace, SFMono-Regular, Menlo, monospace;
  }

  *,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
  html{scroll-behavior:smooth;}
  body{font-family:var(--font-sans);background:var(--bg);color:var(--text);font-size:16px;line-height:1.55;-webkit-font-smoothing:antialiased;-moz-osx-font-smoothing:grayscale;}

  /* ───── Generic layout helpers ───── */
  .wrap{max-width:1180px;margin:0 auto;padding:0 32px;}
  .wrap-narrow{max-width:920px;margin:0 auto;padding:0 32px;}
  @media (max-width:680px){
    .wrap, .wrap-narrow{padding:0 22px;}
  }

  /* ───── Top nav ───── */
  .topnav{position:sticky;top:0;z-index:100;background:rgba(253,255,254,0.85);backdrop-filter:blur(10px);-webkit-backdrop-filter:blur(10px);border-bottom:1px solid transparent;transition:border-color .2s;}
  .topnav.scrolled{border-bottom-color:var(--border);}
  .topnav-inner{display:flex;align-items:center;justify-content:space-between;height:72px;}
  .brand{display:flex;align-items:center;gap:10px;text-decoration:none;color:var(--text);}
  .brand-mark{width:32px;height:32px;display:block;}
  .brand-wordmark{font-size:20px;font-weight:600;letter-spacing:-0.02em;}
  .topnav-links{display:flex;align-items:center;gap:8px;}
  .topnav-link{padding:9px 14px;border-radius:999px;font-size:15px;font-weight:500;color:var(--text);text-decoration:none;transition:background .15s;}
  .topnav-link:hover{background:var(--surface2);color:var(--text);}
  .topnav-link.primary{background:var(--text);color:#fff;}
  .topnav-link.primary:hover{background:#082018;color:#fff;}
  @media (max-width:680px){
    .topnav-inner{height:60px;}
    .topnav-link.hide-sm{display:none;}
  }

  /* ───── Hero ───── */
  .hero{padding:64px 0 96px;position:relative;overflow:hidden;}
  .hero-grid{display:grid;grid-template-columns:1.05fr 1fr;gap:64px;align-items:center;}
  .eyebrow{display:inline-flex;align-items:center;gap:8px;font-size:13px;font-weight:500;color:var(--accent);letter-spacing:-0.005em;background:var(--accent-light);padding:7px 13px;border-radius:999px;margin-bottom:24px;}
  .eyebrow::before{content:"";width:6px;height:6px;border-radius:50%;background:var(--brand-light);box-shadow:0 0 0 4px rgba(18,209,107,0.18);}
  .hero h1{font-size:clamp(40px,5.4vw,72px);font-weight:500;letter-spacing:-0.035em;line-height:0.97;color:var(--text);margin-bottom:20px;}
  .hero h1 .accent{color:var(--accent);}
  .hero-subhead{font-size:clamp(17px,1.6vw,21px);font-weight:400;color:var(--text2);line-height:1.5;letter-spacing:-0.01em;max-width:520px;margin-bottom:36px;}
  .hero-subhead strong{color:var(--text);font-weight:500;}

  /* persona switcher */
  .persona-block{margin-bottom:32px;}
  .persona-label{font-size:13px;color:var(--text2);margin-bottom:10px;display:flex;align-items:center;gap:8px;}
  .persona-label::before{content:"";width:18px;height:1.5px;background:var(--border2);}
  .persona-switch{display:inline-flex;padding:5px;background:var(--surface);border:1.5px solid var(--border);border-radius:999px;gap:2px;position:relative;}
  .persona-btn{appearance:none;background:transparent;border:none;font-family:inherit;font-size:14px;font-weight:500;color:var(--text2);padding:10px 18px;border-radius:999px;cursor:pointer;transition:color .2s;position:relative;z-index:2;letter-spacing:-0.005em;}
  .persona-btn[aria-pressed="true"]{color:#fff;}
  .persona-btn:hover:not([aria-pressed="true"]){color:var(--text);}
  .persona-slider{position:absolute;top:5px;bottom:5px;background:var(--text);border-radius:999px;transition:left .35s cubic-bezier(0.34,1.1,0.64,1),width .35s cubic-bezier(0.34,1.1,0.64,1);z-index:1;}
  .persona-tagline{margin-top:18px;font-size:16px;color:var(--text);font-style:italic;font-weight:400;line-height:1.45;max-width:520px;border-left:2px solid var(--accent);padding-left:14px;min-height:48px;transition:opacity .2s;}

  /* hero CTAs */
  .cta-row{display:flex;gap:14px;align-items:center;flex-wrap:wrap;}
  .btn{appearance:none;border:none;cursor:pointer;font-family:inherit;font-size:16px;font-weight:500;letter-spacing:-0.01em;height:54px;padding:0 26px;border-radius:999px;display:inline-flex;align-items:center;gap:10px;text-decoration:none;transition:background .15s,transform .15s,box-shadow .15s;}
  .btn-primary{background:var(--accent);color:#fff;box-shadow:0 4px 14px rgba(0,152,89,0.22);}
  .btn-primary:hover{background:var(--accent-hover);color:#fff;}
  .btn-primary:active{background:var(--accent2);}
  .btn-ghost{background:transparent;color:var(--text);border:1.5px solid var(--border);}
  .btn-ghost:hover{background:var(--surface2);border-color:var(--border2);color:var(--text);}
  .btn .arrow{transition:transform .2s;}
  .btn:hover .arrow{transform:translateX(3px);}

  .hero-micro{margin-top:20px;font-size:13px;color:var(--text2);display:flex;align-items:center;gap:10px;flex-wrap:wrap;}
  .hero-micro .dot{width:3px;height:3px;border-radius:50%;background:var(--text3);}
  .hero-micro .gh-stat{display:inline-flex;align-items:center;gap:6px;}
  .hero-micro svg{width:14px;height:14px;color:var(--text2);}

  /* hero visual — composited checkout mockup */
  .hero-visual{position:relative;}
  .checkout-card{background:#fff;border:1.5px solid var(--border);border-radius:24px;box-shadow:0 24px 60px rgba(12,49,36,0.10),0 4px 14px rgba(12,49,36,0.04);padding:0;overflow:hidden;position:relative;}
  .wc-bar{display:flex;align-items:center;gap:10px;padding:14px 20px;background:#fafbfa;border-bottom:1px solid var(--border);font-size:12px;font-weight:500;color:var(--text2);}
  .wc-dots{display:flex;gap:6px;}
  .wc-dots span{width:10px;height:10px;border-radius:50%;background:#e4e9e6;}
  .wc-dots span:nth-child(1){background:#FF6058;}
  .wc-dots span:nth-child(2){background:#FFBC2D;}
  .wc-dots span:nth-child(3){background:#28C940;}
  .wc-url{flex:1;text-align:center;font-family:var(--font-mono);font-size:11px;color:var(--text2);background:#fff;border:1px solid var(--border);border-radius:999px;padding:5px 12px;}

  .ck-body{padding:24px 24px 22px;}
  .ck-eyebrow{font-size:11px;font-weight:600;color:var(--text2);letter-spacing:0.08em;text-transform:uppercase;margin-bottom:14px;}
  .ck-order{display:flex;align-items:center;gap:14px;padding:14px;background:var(--surface);border:1px solid var(--border);border-radius:14px;margin-bottom:18px;transition:background .25s;}
  .ck-order-img{width:54px;height:54px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:24px;flex-shrink:0;background:var(--surface2);transition:background .3s;}
  .ck-order-info{flex:1;min-width:0;}
  .ck-order-name{font-size:15px;font-weight:500;color:var(--text);letter-spacing:-0.01em;margin-bottom:2px;line-height:1.25;}
  .ck-order-sub{font-size:12px;color:var(--text2);}
  .ck-order-price{font-size:16px;font-weight:500;color:var(--text);letter-spacing:-0.01em;}

  .ck-meta{display:flex;justify-content:space-between;padding:8px 0;border-bottom:1px dashed var(--border);font-size:13px;color:var(--text2);}
  .ck-meta:last-of-type{border-bottom:none;margin-bottom:14px;}
  .ck-meta strong{color:var(--text);font-weight:500;}

  .ck-method{display:flex;align-items:center;gap:12px;padding:14px 16px;background:var(--accent-light);border:1.5px solid var(--accent);border-radius:14px;margin-bottom:12px;position:relative;}
  .ck-method-radio{width:18px;height:18px;border-radius:50%;border:2px solid var(--accent);display:flex;align-items:center;justify-content:center;flex-shrink:0;}
  .ck-method-radio::after{content:"";width:8px;height:8px;border-radius:50%;background:var(--accent);}
  .ck-method-logo{width:28px;height:28px;}
  .ck-method-text{flex:1;}
  .ck-method-title{font-size:14px;font-weight:500;color:var(--text);}
  .ck-method-sub{font-size:11px;color:var(--text2);font-family:var(--font-mono);}
  .ck-method-fee{font-size:11px;color:var(--accent);font-weight:500;background:#fff;padding:3px 8px;border-radius:999px;border:1px solid #d6efe2;}

  .ck-method-other{display:flex;align-items:center;gap:12px;padding:12px 16px;border:1.5px solid var(--border);border-radius:14px;margin-bottom:8px;font-size:14px;color:var(--text2);}
  .ck-method-other .other-radio{width:18px;height:18px;border-radius:50%;border:2px solid var(--border-gray);flex-shrink:0;}
  .ck-method-other .other-name{flex:1;}
  .ck-method-other .other-fee{font-size:11px;color:var(--text3);}

  .ck-pay-btn{width:100%;height:50px;background:var(--text);color:#fff;border:none;border-radius:999px;font-family:inherit;font-size:15px;font-weight:500;letter-spacing:-0.01em;margin-top:14px;display:flex;align-items:center;justify-content:center;gap:8px;cursor:pointer;}
  .ck-pay-btn:hover{background:#082018;}

  /* floating confirmation card */
  .conf-card{position:absolute;bottom:-32px;right:-28px;width:235px;background:#fff;border:1.5px solid var(--border);border-radius:18px;box-shadow:0 12px 36px rgba(12,49,36,0.16);padding:14px 16px;z-index:5;animation:floatIn .6s 0.3s cubic-bezier(0.34,1.1,0.64,1) backwards;}
  @keyframes floatIn{from{opacity:0;transform:translateY(20px) scale(0.95);}to{opacity:1;transform:translateY(0) scale(1);}}
  .conf-head{display:flex;align-items:center;gap:8px;font-size:12px;font-weight:500;color:var(--text);margin-bottom:10px;}
  .conf-head .dot{width:8px;height:8px;border-radius:50%;background:var(--brand-light);box-shadow:0 0 0 3px rgba(18,209,107,0.18);}
  .conf-row{display:flex;justify-content:space-between;font-size:12px;padding:4px 0;}
  .conf-row .lbl{color:var(--text2);}
  .conf-row .val{color:var(--text);font-weight:500;}
  .conf-row .val.mono{font-family:var(--font-mono);font-weight:400;font-size:11px;}
  .conf-amount{font-size:24px;font-weight:600;letter-spacing:-0.02em;color:var(--accent);margin:6px 0 8px;}
  .conf-amount small{font-size:11px;color:var(--text2);font-weight:400;margin-left:4px;}

  @media (max-width:1000px){
    .hero{padding:48px 0 80px;}
    .hero-grid{grid-template-columns:1fr;gap:48px;}
    .conf-card{right:8px;bottom:-20px;}
  }
  @media (max-width:680px){
    .hero{padding:32px 0 60px;}
    .persona-switch{display:flex;width:100%;}
    .persona-btn{flex:1;padding:10px 8px;font-size:13px;}
    .conf-card{display:none;}
    .ck-body{padding:18px;}
    .btn{width:100%;justify-content:center;}
    .cta-row{flex-direction:column;align-items:stretch;}
  }

  /* ───── Trust strip / chain logos ───── */
  .strip{padding:36px 0;border-top:1px solid var(--border);border-bottom:1px solid var(--border);background:var(--surface);}
  .strip-inner{display:flex;align-items:center;justify-content:space-between;gap:32px;flex-wrap:wrap;}
  .strip-label{font-size:13px;color:var(--text2);letter-spacing:-0.005em;}
  .strip-chains{display:flex;align-items:center;gap:28px;flex-wrap:wrap;}
  .chain-pill{display:flex;align-items:center;gap:8px;font-size:13px;font-weight:500;color:var(--text);}
  .chain-pill img{width:24px;height:24px;border-radius:50%;}
  @media (max-width:680px){
    .strip-chains{gap:18px;}
    .chain-pill span{display:none;}
    .chain-pill img{width:30px;height:30px;}
  }

  /* ───── Pillars ───── */
  .section{padding:120px 0;}
  .section-tight{padding:88px 0;}
  @media (max-width:680px){
    .section{padding:72px 0;}
    .section-tight{padding:56px 0;}
  }
  .section-head{margin-bottom:56px;max-width:680px;}
  .section-eyebrow{display:inline-block;font-size:12px;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;color:var(--accent);margin-bottom:14px;}
  .section-title{font-size:clamp(32px,4vw,52px);font-weight:500;letter-spacing:-0.03em;line-height:1.05;color:var(--text);}
  .section-sub{margin-top:16px;font-size:18px;color:var(--text2);line-height:1.55;max-width:580px;}

  .pillars{display:grid;grid-template-columns:repeat(3,1fr);gap:24px;}
  .pillar{background:var(--surface);border:1.5px solid var(--border);border-radius:24px;padding:32px;display:flex;flex-direction:column;gap:16px;position:relative;transition:border-color .2s,background .2s;}
  .pillar:hover{border-color:var(--border2);background:#fff;}
  .pillar-num{font-family:var(--font-mono);font-size:12px;color:var(--accent);}
  .pillar h3{font-size:22px;font-weight:500;letter-spacing:-0.02em;line-height:1.2;color:var(--text);}
  .pillar p{font-size:15px;line-height:1.6;color:var(--text2);}
  .pillar-accent{margin-top:auto;padding:14px 16px;background:var(--accent-light);border-radius:14px;font-size:14px;color:var(--accent2);line-height:1.45;font-weight:500;letter-spacing:-0.005em;transition:opacity .2s;border-left:3px solid var(--accent);}
  @media (max-width:900px){
    .pillars{grid-template-columns:1fr;gap:16px;}
    .pillar{padding:26px;}
  }

  /* ───── How it works ───── */
  .how-bg{background:linear-gradient(180deg,#fff 0%,var(--surface2) 100%);}
  .how-steps{display:grid;grid-template-columns:repeat(3,1fr);gap:28px;position:relative;}
  .how-steps::before{content:"";position:absolute;top:38px;left:9%;right:9%;height:1.5px;background:repeating-linear-gradient(90deg,var(--border2) 0 8px,transparent 8px 14px);z-index:0;}
  .how-step{background:#fff;border:1.5px solid var(--border);border-radius:24px;padding:32px;position:relative;z-index:1;}
  .how-num{width:48px;height:48px;border-radius:50%;background:var(--accent);color:#fff;font-size:18px;font-weight:500;display:flex;align-items:center;justify-content:center;margin-bottom:24px;font-family:var(--font-sans);box-shadow:0 0 0 8px #fff,0 0 0 9.5px var(--border);}
  .how-step h4{font-size:20px;font-weight:500;letter-spacing:-0.02em;line-height:1.25;margin-bottom:10px;color:var(--text);}
  .how-step p{font-size:14.5px;line-height:1.6;color:var(--text2);}
  @media (max-width:900px){
    .how-steps{grid-template-columns:1fr;gap:16px;}
    .how-steps::before{display:none;}
  }

  /* ───── Features ───── */
  .features{display:grid;grid-template-columns:1fr 1fr;gap:24px;}
  .feature{background:var(--surface);border:1.5px solid var(--border);border-radius:24px;overflow:hidden;display:flex;flex-direction:column;transition:border-color .2s,box-shadow .2s;}
  .feature:hover{border-color:var(--border2);box-shadow:var(--shadow-md);}
  .feature-shot{background:#F0F1F1;border-bottom:1px solid var(--border);padding:28px 28px 0;display:flex;align-items:flex-end;justify-content:center;min-height:280px;overflow:hidden;position:relative;}
  .feature-shot img{display:block;max-width:100%;border-radius:12px 12px 0 0;box-shadow:0 -10px 30px rgba(0,0,0,0.06);}
  .feature-body{padding:28px;}
  .feature-body h4{font-size:21px;font-weight:500;letter-spacing:-0.02em;color:var(--text);margin-bottom:10px;line-height:1.25;}
  .feature-body p{font-size:14.5px;line-height:1.6;color:var(--text2);}
  .features-extra{margin-top:32px;padding:28px;background:var(--surface2);border-radius:18px;font-size:15px;line-height:1.7;color:var(--text);}
  .features-extra strong{color:var(--accent2);font-weight:600;}
  @media (max-width:900px){
    .features{grid-template-columns:1fr;}
    .feature-shot{min-height:220px;padding:22px 22px 0;}
    .feature-body{padding:24px;}
  }

  /* ───── Pricing ───── */
  .pricing-bg{background:var(--text);color:#fff;position:relative;overflow:hidden;}
  .pricing-bg::before{content:"";position:absolute;top:-40%;right:-15%;width:600px;height:600px;border-radius:50%;background:radial-gradient(circle, rgba(18,209,107,0.22) 0%,transparent 60%);pointer-events:none;}
  .pricing-bg::after{content:"";position:absolute;bottom:-30%;left:-10%;width:500px;height:500px;border-radius:50%;background:radial-gradient(circle, rgba(0,152,89,0.18) 0%,transparent 60%);pointer-events:none;}
  .pricing-bg .section-eyebrow{color:var(--brand-light);}
  .pricing-bg .section-title{color:#fff;}
  .pricing-grid{display:grid;grid-template-columns:1.2fr 1fr;gap:48px;align-items:center;position:relative;z-index:2;}
  .pricing-numbers{display:flex;flex-direction:column;gap:8px;}
  .pricing-big{font-size:clamp(72px,12vw,160px);font-weight:500;letter-spacing:-0.05em;line-height:0.9;color:var(--brand-light);font-feature-settings:"tnum" 1;}
  .pricing-big small{font-size:0.32em;font-weight:400;color:rgba(255,255,255,0.6);margin-left:8px;letter-spacing:-0.02em;}
  .pricing-row{display:flex;align-items:center;gap:14px;font-size:18px;color:rgba(255,255,255,0.85);}
  .pricing-row .dot{width:6px;height:6px;border-radius:50%;background:var(--brand-light);flex-shrink:0;}
  .pricing-row strong{color:#fff;font-weight:500;}
  .pricing-copy{font-size:16px;line-height:1.65;color:rgba(255,255,255,0.78);}
  .pricing-copy p+p{margin-top:14px;}
  .pricing-compare{margin-top:24px;display:flex;flex-direction:column;gap:8px;padding:20px;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);border-radius:18px;}
  .pricing-compare-title{font-size:11px;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;color:rgba(255,255,255,0.45);margin-bottom:6px;}
  .compare-row{display:grid;grid-template-columns:1fr auto;gap:12px;font-size:14px;align-items:center;}
  .compare-row .name{color:rgba(255,255,255,0.72);}
  .compare-row .fee{font-family:var(--font-mono);color:rgba(255,255,255,0.86);font-size:13px;}
  .compare-row.us .name{color:#fff;font-weight:500;}
  .compare-row.us .fee{color:var(--brand-light);font-weight:500;}
  @media (max-width:900px){
    .pricing-grid{grid-template-columns:1fr;gap:32px;}
  }

  /* ───── FAQ ───── */
  .faq-list{display:flex;flex-direction:column;gap:12px;}
  .faq-item{background:var(--surface);border:1.5px solid var(--border);border-radius:18px;transition:border-color .2s,background .2s;overflow:hidden;}
  .faq-item:hover{border-color:var(--border2);}
  .faq-item[open]{background:#fff;border-color:var(--border2);}
  .faq-item summary{list-style:none;cursor:pointer;padding:22px 28px;display:flex;align-items:center;justify-content:space-between;gap:24px;font-size:18px;font-weight:500;letter-spacing:-0.015em;color:var(--text);}
  .faq-item summary::-webkit-details-marker{display:none;}
  .faq-icon{flex-shrink:0;width:32px;height:32px;border-radius:50%;background:var(--surface2);display:flex;align-items:center;justify-content:center;transition:background .2s,transform .25s;}
  .faq-item[open] .faq-icon{background:var(--accent);transform:rotate(45deg);}
  .faq-icon svg{width:14px;height:14px;color:var(--text);transition:color .2s;}
  .faq-item[open] .faq-icon svg{color:#fff;}
  .faq-content{padding:0 28px 24px;font-size:15.5px;line-height:1.7;color:var(--text2);max-width:780px;}
  .faq-content a{color:var(--accent);font-weight:500;}
  @media (max-width:680px){
    .faq-item summary{padding:18px 22px;font-size:16px;gap:14px;}
    .faq-content{padding:0 22px 20px;font-size:14.5px;}
  }

  /* ───── Final CTA ───── */
  .final-cta{background:var(--surface2);border-radius:32px;padding:80px 56px;text-align:center;position:relative;overflow:hidden;}
  .final-cta::before{content:"";position:absolute;top:-50%;left:50%;transform:translateX(-50%);width:700px;height:700px;border-radius:50%;background:radial-gradient(circle, rgba(0,152,89,0.10) 0%,transparent 65%);pointer-events:none;}
  .final-cta-content{position:relative;z-index:2;}
  .final-cta h2{font-size:clamp(32px,4.5vw,52px);font-weight:500;letter-spacing:-0.03em;line-height:1.05;color:var(--text);max-width:680px;margin:0 auto 20px;}
  .final-cta p.lead{font-size:17px;color:var(--text2);max-width:520px;margin:0 auto 36px;line-height:1.55;}
  .final-cta-row{display:flex;justify-content:center;gap:14px;flex-wrap:wrap;}
  .final-cta-micro{margin-top:28px;font-size:13px;color:var(--text2);display:flex;align-items:center;justify-content:center;gap:12px;flex-wrap:wrap;}
  .final-cta-micro .dot{width:3px;height:3px;border-radius:50%;background:var(--text3);}
  @media (max-width:680px){
    .final-cta{padding:56px 24px;border-radius:24px;}
    .final-cta-row{flex-direction:column;align-items:stretch;}
  }

  /* ───── Footer ───── */
  footer{padding:56px 0 40px;border-top:1px solid var(--border);}
  .foot-grid{display:flex;justify-content:space-between;align-items:flex-start;gap:40px;flex-wrap:wrap;margin-bottom:40px;}
  .foot-brand{max-width:280px;}
  .foot-brand p{font-size:13px;color:var(--text2);line-height:1.5;margin-top:14px;}
  .foot-cols{display:flex;gap:64px;flex-wrap:wrap;}
  .foot-col h5{font-size:12px;font-weight:600;letter-spacing:0.06em;text-transform:uppercase;color:var(--text3);margin-bottom:14px;}
  .foot-col ul{list-style:none;display:flex;flex-direction:column;gap:9px;}
  .foot-col a{font-size:14px;color:var(--text2);text-decoration:none;transition:color .15s;}
  .foot-col a:hover{color:var(--accent);}
  .foot-bottom{display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:16px;padding-top:24px;border-top:1px solid var(--border);font-size:13px;color:var(--text3);}
  .foot-bottom .links{display:flex;gap:20px;}
  .foot-bottom a{color:var(--text3);text-decoration:none;}
  .foot-bottom a:hover{color:var(--accent);}
  @media (max-width:680px){
    .foot-cols{gap:36px;}
  }

