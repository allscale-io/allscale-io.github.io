<script is:inline>
(function(){
  const personas = {
    ecom: {
      tagline: "Your store, your customers, your wallet. Stop sending 3% to your processor every time someone checks out.",
      order: {
        emoji: "👕",
        bg: "linear-gradient(135deg,#FFE4E1 0%,#FFF1ED 100%)",
        name: "Heavyweight French-terry hoodie",
        sub: "Mid-grey · Size L · Qty 1",
        price: "$45.00",
        usdt: "+45.00",
        url: "acme-outfitters.com / checkout"
      },
      accents: {
        "non-custodial": "Your revenue isn't trapped during a refund dispute.",
        "fees": "On a $1,000-a-day store, that's $24 daily in fees vs $90 with Stripe.",
        "settlement": "Cash-flow positive from minute one of every sale."
      }
    },
    virtual: {
      tagline: "Invoice, deliver, get paid. Settle in seconds, no payout schedule, no chargebacks on completed work.",
      order: {
        emoji: "🗓",
        bg: "linear-gradient(135deg,#EDE9FE 0%,#F5F3FF 100%)",
        name: "1-hour strategy consult",
        sub: "Tuesday, May 26 · 14:00 PT · Zoom",
        price: "$120.00",
        usdt: "+120.00",
        url: "marie-consulting.com / checkout"
      },
      accents: {
        "non-custodial": "Completed work means received payment — no \"pending\" for 5–10 business days.",
        "fees": "Higher-ticket sales compound the savings every transaction.",
        "settlement": "Funds in your wallet before the consult ends."
      }
    },
    crypto: {
      tagline: "Already in the stablecoin economy. Accept payments in the same USDT you settle in.",
      order: {
        emoji: "🔐",
        bg: "linear-gradient(135deg,#FEF3C7 0%,#FFFBEB 100%)",
        name: "Cold-storage hardware wallet · Pro",
        sub: "Steel enclosure · Secure element · Black",
        price: "$300.00",
        usdt: "+300.00",
        url: "vault-shop.xyz / checkout"
      },
      accents: {
        "non-custodial": "Your treasury already runs on-chain. Your payment processor should too.",
        "fees": "Wallet-to-wallet settlement, priced like wallet-to-wallet.",
        "settlement": "Settlement = where your business already operates."
      }
    }
  };

  const $ = (s,r)=>(r||document).querySelector(s);
  const $$ = (s,r)=>Array.from((r||document).querySelectorAll(s));
  const switchEl = $('#personaSwitch');
  const slider = $('#personaSlider');
  const buttons = $$('.persona-btn', switchEl);
  const tagline = $('#personaTagline');
  const orderName = $('#ckOrderName');
  const orderSub = $('#ckOrderSub');
  const orderPrice = $('#ckOrderPrice');
  const orderImg = $('#ckOrderImg');
  const ckTotal = $('#ckTotal');
  const confAmount = $('#confAmount');
  const wcUrl = $('.wc-url');
  const pillarAccents = $$('.pillar-accent');

  function positionSlider(btn){
    const rect = btn.getBoundingClientRect();
    const wrapperRect = switchEl.getBoundingClientRect();
    slider.style.left = (rect.left - wrapperRect.left) + 'px';
    slider.style.width = rect.width + 'px';
  }

  function applyPersona(name, animate){
    if(animate === undefined) animate = true;
    const p = personas[name];
    document.body.dataset.persona = name;
    buttons.forEach(function(b){
      const on = b.dataset.persona === name;
      b.setAttribute('aria-pressed', on ? 'true' : 'false');
      if(on) positionSlider(b);
    });
    if(animate){
      tagline.style.opacity = 0;
      setTimeout(function(){
        tagline.textContent = p.tagline;
        tagline.style.opacity = 1;
      }, 160);
    } else {
      tagline.textContent = p.tagline;
    }

    orderName.textContent = p.order.name;
    orderSub.textContent = p.order.sub;
    orderPrice.textContent = p.order.price;
    orderImg.textContent = p.order.emoji;
    orderImg.style.background = p.order.bg;
    ckTotal.textContent = p.order.price;
    confAmount.innerHTML = p.order.usdt + '<small>USDT</small>';
    wcUrl.textContent = p.order.url;

    pillarAccents.forEach(function(el){
      const key = el.dataset.accent;
      el.style.opacity = 0;
      setTimeout(function(){
        el.textContent = p.accents[key];
        el.style.opacity = 1;
      }, 160);
    });
  }

  buttons.forEach(function(b){
    b.addEventListener('click', function(){ applyPersona(b.dataset.persona); });
  });

  function init(){ applyPersona('ecom', false); }
  if(document.fonts && document.fonts.ready){
    document.fonts.ready.then(init);
  } else {
    init();
  }
  window.addEventListener('resize', function(){
    const active = buttons.find(function(b){ return b.getAttribute('aria-pressed')==='true'; });
    if(active) positionSlider(active);
  });

  const nav = document.getElementById('topnav');
  function onScroll(){
    if(window.scrollY > 8) nav.classList.add('scrolled');
    else nav.classList.remove('scrolled');
  }
  window.addEventListener('scroll', onScroll, {passive:true});
  onScroll();
})();
</script>

</body>
</html>
