<script is:inline>
  // Nav border on scroll
  const nav = document.getElementById('nav');
  const onScroll = () => nav.classList.toggle('scrolled', window.scrollY > 8);
  document.addEventListener('scroll', onScroll, { passive: true });
  onScroll();

  // Copy buttons
  document.querySelectorAll('[data-copy]').forEach(btn => {
    btn.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(btn.dataset.copy);
        btn.classList.add('copied');
        const lbl = btn.querySelector('.lbl, span:last-child');
        const ic1 = btn.querySelector('.ic-copy');
        const ic2 = btn.querySelector('.ic-check');
        const prev = lbl ? lbl.textContent : null;
        if (lbl) lbl.textContent = 'Copied';
        if (ic1) ic1.style.display = 'none';
        if (ic2) ic2.style.display = '';
        setTimeout(() => {
          btn.classList.remove('copied');
          if (lbl && prev) lbl.textContent = prev;
          if (ic1) ic1.style.display = '';
          if (ic2) ic2.style.display = 'none';
        }, 1600);
      } catch (e) {
        const t = document.createElement('textarea');
        t.value = btn.dataset.copy;
        document.body.appendChild(t);
        t.select();
        try { document.execCommand('copy'); } catch {}
        t.remove();
      }
    });
  });

  // Install tabs
  const tabs = document.querySelectorAll('.install-tab');
  const panels = document.querySelectorAll('.install-panel');
  tabs.forEach(t => {
    t.addEventListener('click', () => {
      tabs.forEach(x => x.classList.remove('active'));
      panels.forEach(p => p.classList.remove('active'));
      t.classList.add('active');
      const target = t.dataset.tab;
      const panel = document.querySelector(`[data-panel="${target}"]`);
      if (panel) panel.classList.add('active');
    });
  });
</script>
