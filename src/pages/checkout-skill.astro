---
// AllScale Checkout Skill — landing page
// Design handoff: 2026-05 AllScale checkout skill / Landing Page.html
---
<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<title>AllScale Checkout Skill — Integrate stablecoin checkout by talking to your AI agent</title>
<meta name="description" content="A portable, agent-agnostic prompt that walks any AI coding agent through wiring AllScale Checkout into your app — credentials, signing, polling, webhooks. One Markdown file. No SDK." />
<link rel="icon" href="/allscale-logo.png" type="image/png" />
<meta property="og:title" content="AllScale Checkout Skill" />
<meta property="og:description" content="Integrate stablecoin checkout by talking to your AI agent. One Markdown file. No SDK." />
<meta property="og:url" content="https://labs.allscale.io/checkout-skill" />
<meta property="og:type" content="website" />

<style is:global>
  /* ─────────────────────────────────────────────────────────────
     AllScale Design System — colors & type
     ───────────────────────────────────────────────────────────── */

  @import url('https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&display=swap');

  @font-face {
    font-family: 'Archivo';
    font-style: normal;
    font-weight: 100 900;
    font-stretch: 62.5% 125%;
    font-display: swap;
    src: url('/fonts/Archivo-VariableFont.ttf') format('truetype-variations'),
         url('/fonts/Archivo-VariableFont.ttf') format('truetype');
  }

  :root {
    --bg:           #FDFFFE;
    --bg-white:     #FFFFFF;
    --surface:      #FAFBFA;
    --surface2:     #F2F8F5;
    --surface3:     #E5EEEA;

    --border:       #E5EEEA;
    --border-gray:  #E4E4E4;
    --border2:      #C5DDD4;

    --text:         #0C3124;
    --text2:        #83968F;
    --text3:        #B0C4BB;
    --text-dark:    #0D0D0D;

    --accent:       #009859;
    --accent-hover: #0CAA67;
    --accent2:      #087E4C;
    --accent-glow:  #F2F8F5;
    --accent-light: #E5FAF1;
    --brand-light:  #12D16B;

    --orange:       #F59E0B;
    --orange-soft:  rgba(245,158,11,0.12);
    --red:          #E53E3E;
    --red-soft:     rgba(229,62,62,0.08);
    --green:        #009859;
    --green-soft:   rgba(0,152,89,0.10);
    --blue:         #2563EB;
    --blue-soft:    rgba(59,130,246,0.10);
    --purple:       #7C3AED;
    --purple-soft:  rgba(139,92,246,0.10);

    --shadow:       0 8px 40px rgba(0,0,0,0.10);
    --shadow-md:    0 4px 24px rgba(0,0,0,0.08);
    --shadow-sm:    0 2px 10px rgba(0,152,89,0.10);
    --shadow-phone: 0 32px 80px rgba(0,0,0,0.5);

    --radius-card:  18px;
    --radius-row:   12px;
    --radius-modal: 27px;
    --radius-modal-sm: 24px;
    --radius-btn:   999px;

    --btn-h:        50px;
    --btn-compact-h:39px;
    --input-h:      48px;
    --topbar-h:     64px;

    --font-sans:    'Archivo', system-ui, -apple-system, sans-serif;
    --font-mono:    'DM Mono', ui-monospace, SFMono-Regular, Menlo, monospace;
  }

  html, body {
    font-family: var(--font-sans);
    color: var(--text);
    background: var(--bg);
    font-size: 14px;
    line-height: 1.5;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  /* ────────────────────────────────────────────────────────────
     Page-level resets
     ──────────────────────────────────────────────────────────── */
  *, *::before, *::after { box-sizing: border-box; }
  html, body { margin: 0; padding: 0; }
  body { background: var(--bg); overflow-x: hidden; }
  img, svg { display: block; max-width: 100%; }
  button { font: inherit; color: inherit; background: none; border: none; padding: 0; cursor: pointer; }
  a { color: var(--accent); text-decoration: none; }

  /* ────────────────────────────────────────────────────────────
     Layout primitives
     ──────────────────────────────────────────────────────────── */
  .container { width: 100%; max-width: 1180px; margin: 0 auto; padding: 0 28px; }
  .section { padding: 96px 0; position: relative; }
  .section + .section { border-top: 1px solid var(--border); }
  .eyebrow {
    font-size: 11.5px; font-weight: 700; letter-spacing: 0.12em;
    color: var(--accent); text-transform: uppercase;
    display: inline-flex; align-items: center; gap: 8px;
  }
  .eyebrow::before {
    content: ""; width: 6px; height: 6px; border-radius: 50%;
    background: var(--accent); box-shadow: 0 0 0 4px var(--accent-light);
  }
  .section-title {
    font-family: var(--font-sans);
    font-size: 44px; font-weight: 500; letter-spacing: -0.025em;
    color: var(--text); line-height: 1.05; margin: 14px 0 14px;
    text-wrap: balance;
  }
  .section-sub {
    font-size: 18px; color: var(--text2); max-width: 620px;
    line-height: 1.45; text-wrap: pretty; margin: 0;
  }

  /* ────────────────────────────────────────────────────────────
     Top nav
     ──────────────────────────────────────────────────────────── */
  .nav {
    position: sticky; top: 0; z-index: 50;
    background: rgba(253,255,254,0.82);
    backdrop-filter: saturate(140%) blur(10px);
    -webkit-backdrop-filter: saturate(140%) blur(10px);
    border-bottom: 1px solid transparent;
    transition: border-color .2s ease;
  }
  .nav.scrolled { border-bottom-color: var(--border); }
  .nav-inner {
    display: flex; align-items: center; justify-content: space-between;
    height: var(--topbar-h);
  }
  .nav-brand {
    display: flex; align-items: center; gap: 10px;
    text-decoration: none; color: var(--text);
  }
  .nav-brand img { height: 22px; width: auto; }
  .nav-brand .pipe { width: 1px; height: 18px; background: var(--border2); }
  .nav-brand .sub {
    font-size: 14px; font-weight: 500; color: var(--text2);
    letter-spacing: -0.01em;
  }
  .nav-back {
    display: inline-flex; align-items: center; gap: 6px;
    font-size: 12.5px; color: var(--text2);
    padding: 4px 10px 4px 8px;
    border-radius: 999px;
    border: 1px solid var(--border);
    background: var(--bg-white);
    transition: color .15s ease, border-color .15s ease;
  }
  .nav-back:hover { color: var(--text); border-color: var(--border2); }
  .nav-back svg { width: 11px; height: 11px; }
  .nav-links { display: flex; align-items: center; gap: 28px; }
  .nav-link {
    color: var(--text); font-size: 14px; font-weight: 500;
    letter-spacing: -0.01em; opacity: .82;
    transition: opacity .15s ease;
  }
  .nav-link:hover { opacity: 1; color: var(--text); }
  .nav-cta {
    display: inline-flex; align-items: center; gap: 6px;
    height: 39px; padding: 0 18px;
    border-radius: var(--radius-btn);
    background: var(--accent); color: white;
    font-size: 14px; font-weight: 500; letter-spacing: -0.01em;
    transition: background .15s ease;
  }
  .nav-cta:hover { background: var(--accent-hover); color: white; }
  .nav-cta svg { width: 14px; height: 14px; }

  @media (max-width: 760px) {
    .nav-links { display: none; }
    .nav-back { display: none; }
    .nav-cta { padding: 0 14px; font-size: 13px; height: 36px; }
  }

  /* ────────────────────────────────────────────────────────────
     Hero
     ──────────────────────────────────────────────────────────── */
  .hero { padding: 88px 0 96px; position: relative; overflow: hidden; }
  .hero::before {
    content: ""; position: absolute; inset: -200px -200px auto auto;
    width: 720px; height: 720px; border-radius: 50%;
    background: radial-gradient(closest-side, rgba(18,209,107,0.18), transparent 70%);
    pointer-events: none; z-index: 0;
  }
  .hero-grid {
    position: relative; z-index: 1;
    display: grid; grid-template-columns: 1.05fr 0.95fr;
    gap: 64px; align-items: center;
  }
  .hero-eyebrow-row {
    display: flex; align-items: center; gap: 12px; flex-wrap: wrap;
    margin-bottom: 22px;
  }
  .hero-eyebrow-row .pill-muted {
    display: inline-flex; align-items: center; gap: 6px;
    height: 26px; padding: 0 11px;
    border-radius: 999px;
    background: var(--surface2); color: var(--text2);
    font-size: 12px; font-weight: 500; letter-spacing: -0.005em;
  }
  .hero-eyebrow-row .pill-muted .dot {
    width: 6px; height: 6px; border-radius: 50%; background: var(--accent);
  }

  .hero h1 {
    font-family: var(--font-sans);
    font-size: 64px; font-weight: 500; letter-spacing: -0.035em;
    line-height: 1.02; color: var(--text);
    margin: 0 0 22px; text-wrap: balance;
  }
  .hero h1 em {
    font-style: normal; color: var(--accent);
    display: inline;
  }
  .hero-sub {
    font-size: 19px; line-height: 1.5; color: var(--text2);
    max-width: 540px; margin: 0 0 28px;
    text-wrap: pretty;
  }

  .magic-card {
    background: var(--bg-white);
    border: 1.5px solid var(--border);
    border-radius: var(--radius-card);
    padding: 18px 20px;
    display: flex; align-items: center; gap: 14px;
    box-shadow: var(--shadow-sm);
    max-width: 560px;
  }
  .magic-card .prompt-chev {
    flex: 0 0 auto;
    width: 28px; height: 28px; border-radius: 8px;
    background: var(--accent-light); color: var(--accent);
    display: flex; align-items: center; justify-content: center;
    font-family: var(--font-mono); font-size: 14px; font-weight: 500;
  }
  .magic-card .magic-text {
    flex: 1 1 auto; min-width: 0;
    font-family: var(--font-mono); font-size: 14.5px;
    color: var(--text); white-space: nowrap;
    overflow: hidden; text-overflow: ellipsis;
  }
  .magic-card .magic-text .accent { color: var(--accent); }
  .magic-card .copy-btn {
    flex: 0 0 auto;
    display: inline-flex; align-items: center; gap: 6px;
    height: 34px; padding: 0 14px;
    border-radius: var(--radius-btn);
    background: var(--text); color: white;
    font-size: 13px; font-weight: 500; letter-spacing: -0.005em;
    transition: background .15s ease, transform .15s ease;
  }
  .magic-card .copy-btn:hover { background: #0a2419; }
  .magic-card .copy-btn.copied { background: var(--accent); }
  .magic-card .copy-btn svg { width: 13px; height: 13px; }

  .hero-meta-row {
    display: flex; align-items: center; gap: 18px;
    margin-top: 22px; flex-wrap: wrap;
  }
  .hero-meta-row .meta {
    display: inline-flex; align-items: center; gap: 7px;
    font-size: 13px; color: var(--text2);
  }
  .hero-meta-row .meta svg { width: 14px; height: 14px; color: var(--accent); }

  .chat-mock {
    position: relative;
    border: 1.5px solid var(--border);
    border-radius: 22px;
    background: var(--bg-white);
    box-shadow: var(--shadow);
    overflow: hidden;
  }
  .chat-mock .cm-bar {
    display: flex; align-items: center; gap: 10px;
    padding: 12px 16px;
    border-bottom: 1px solid var(--border);
    background: var(--surface);
  }
  .cm-bar .dots { display: flex; gap: 6px; }
  .cm-bar .dots span {
    width: 10px; height: 10px; border-radius: 50%;
    background: var(--border2);
  }
  .cm-bar .title {
    margin-left: 6px; font-size: 12.5px; color: var(--text2);
    font-family: var(--font-mono);
  }
  .cm-bar .badge {
    margin-left: auto;
    display: inline-flex; align-items: center; gap: 5px;
    height: 22px; padding: 0 9px;
    border-radius: 999px;
    background: var(--accent-light); color: var(--accent);
    font-size: 11px; font-weight: 600; letter-spacing: -0.005em;
  }
  .cm-bar .badge::before {
    content: ""; width: 6px; height: 6px; border-radius: 50%;
    background: var(--accent); box-shadow: 0 0 0 3px rgba(0,152,89,0.18);
    animation: pulse 2s ease-in-out infinite;
  }
  @keyframes pulse {
    0%, 100% { box-shadow: 0 0 0 3px rgba(0,152,89,0.18); }
    50%      { box-shadow: 0 0 0 5px rgba(0,152,89,0.05); }
  }

  .cm-body { padding: 22px 22px 24px; display: flex; flex-direction: column; gap: 18px; }
  .msg { display: flex; gap: 12px; align-items: flex-start; }
  .msg .avatar {
    flex: 0 0 auto; width: 28px; height: 28px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 11px; font-weight: 700;
  }
  .msg.user .avatar { background: var(--surface3); color: var(--text); }
  .msg.bot  .avatar { background: var(--accent); color: white; }
  .msg .bubble {
    flex: 1 1 auto; min-width: 0;
    padding: 10px 14px;
    border-radius: 14px;
    font-size: 14px; line-height: 1.45;
    color: var(--text);
  }
  .msg.user .bubble {
    background: var(--surface2);
    border-radius: 14px 14px 14px 4px;
  }
  .msg.bot .bubble {
    background: transparent; padding-left: 0;
    color: var(--text);
  }
  .msg.bot .bubble code,
  .msg.user .bubble code {
    font-family: var(--font-mono); font-size: 13px;
    background: var(--bg-white); padding: 1px 6px;
    border: 1px solid var(--border); border-radius: 6px;
    color: var(--text);
  }
  .msg.user .bubble code { background: white; }

  .checklist { list-style: none; margin: 8px 0 0; padding: 0; display: flex; flex-direction: column; gap: 8px; }
  .checklist li {
    display: flex; align-items: center; gap: 9px;
    font-size: 13.5px; color: var(--text);
  }
  .checklist li .ck {
    width: 16px; height: 16px; border-radius: 50%;
    background: var(--accent); color: white;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }
  .checklist li .ck svg { width: 9px; height: 9px; }
  .checklist li.pending .ck {
    background: var(--surface2); color: var(--accent);
    border: 1.5px solid var(--border2);
  }
  .checklist li.pending .ck svg { display: none; }
  .checklist li.pending .ck::after {
    content: ""; width: 8px; height: 8px; border-radius: 50%;
    border: 1.5px solid var(--accent);
    border-top-color: transparent;
    animation: spin 0.9s linear infinite;
  }
  @keyframes spin { to { transform: rotate(360deg); } }
  .checklist li.pending { color: var(--text2); }

  .typing-dots {
    display: inline-flex; gap: 3px; align-items: center;
    height: 18px;
  }
  .typing-dots span {
    width: 6px; height: 6px; border-radius: 50%;
    background: var(--text3);
    animation: bounce 1.2s ease-in-out infinite;
  }
  .typing-dots span:nth-child(2) { animation-delay: 0.15s; }
  .typing-dots span:nth-child(3) { animation-delay: 0.3s; }
  @keyframes bounce {
    0%, 60%, 100% { transform: translateY(0); opacity: .5; }
    30% { transform: translateY(-4px); opacity: 1; }
  }

  @media (max-width: 960px) {
    .hero { padding: 56px 0 64px; }
    .hero-grid { grid-template-columns: 1fr; gap: 36px; }
    .hero h1 { font-size: 44px; letter-spacing: -0.03em; }
    .hero-sub { font-size: 17px; }
    .magic-card .magic-text { font-size: 13px; }
  }
  @media (max-width: 520px) {
    .hero h1 { font-size: 36px; }
    .magic-card { padding: 14px; gap: 10px; }
    .magic-card .copy-btn { padding: 0 12px; height: 32px; }
    .magic-card .magic-text { font-size: 12px; }
  }

  /* ────────────────────────────────────────────────────────────
     Agents strip
     ──────────────────────────────────────────────────────────── */
  .agents {
    padding: 32px 0;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    background: var(--surface);
  }
  .agents-inner {
    display: flex; align-items: center; justify-content: space-between;
    flex-wrap: wrap; gap: 20px;
  }
  .agents-label {
    font-size: 12px; font-weight: 500; letter-spacing: 0.06em;
    color: var(--text2); text-transform: uppercase;
    white-space: nowrap;
  }
  .agents-list {
    display: flex; align-items: center; gap: 28px;
    flex-wrap: wrap;
  }
  .agent-chip {
    display: inline-flex; align-items: center; gap: 8px;
    color: var(--text); font-size: 15px; font-weight: 500;
    letter-spacing: -0.01em;
  }
  .agent-chip .glyph {
    width: 22px; height: 22px; border-radius: 6px;
    display: inline-flex; align-items: center; justify-content: center;
    font-family: var(--font-mono); font-size: 11px; font-weight: 700;
    color: white;
  }
  @media (max-width: 720px) {
    .agents-inner { gap: 16px; justify-content: flex-start; }
    .agents-list { gap: 18px; }
    .agent-chip { font-size: 14px; }
  }

  /* ────────────────────────────────────────────────────────────
     How it works — 3 steps
     ──────────────────────────────────────────────────────────── */
  .steps-grid {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 22px;
    margin-top: 56px;
  }
  .step-card {
    position: relative;
    background: var(--bg-white);
    border: 1.5px solid var(--border);
    border-radius: var(--radius-card);
    padding: 28px;
    display: flex; flex-direction: column; gap: 16px;
    transition: border-color .15s ease, box-shadow .15s ease, transform .2s ease;
  }
  .step-card:hover {
    border-color: var(--border2);
    box-shadow: var(--shadow-sm);
  }
  .step-card .step-num {
    display: inline-flex; align-items: center; justify-content: center;
    width: 32px; height: 32px; border-radius: 50%;
    background: var(--accent-light); color: var(--accent);
    font-family: var(--font-mono); font-size: 13px; font-weight: 500;
  }
  .step-card h3 {
    font-size: 20px; font-weight: 500; letter-spacing: -0.02em;
    color: var(--text); margin: 0;
  }
  .step-card p {
    font-size: 14.5px; line-height: 1.5; color: var(--text2);
    margin: 0; text-wrap: pretty;
  }
  .step-card .step-art {
    margin-top: 8px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 14px;
  }
  .step-card .step-art.mono {
    font-family: var(--font-mono); font-size: 12.5px;
    color: var(--text); line-height: 1.55;
    word-break: break-all;
  }
  .step-card .step-art .accent { color: var(--accent); }
  .step-card .step-art .mute { color: var(--text2); }

  .step-art-list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 8px; }
  .step-art-list li {
    display: flex; align-items: center; gap: 8px;
    font-size: 13px; color: var(--text);
    font-family: var(--font-mono);
  }
  .step-art-list .tick {
    width: 14px; height: 14px; border-radius: 50%;
    background: var(--accent); color: white;
    display: inline-flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }
  .step-art-list .tick svg { width: 8px; height: 8px; }

  .step-art-receipt {
    display: flex; flex-direction: column; gap: 6px;
    font-family: var(--font-mono); font-size: 12.5px;
  }
  .receipt-row { display: flex; justify-content: space-between; }
  .receipt-row .k { color: var(--text2); }
  .receipt-row .v { color: var(--text); }
  .receipt-row.confirmed .v {
    display: inline-flex; align-items: center; gap: 5px;
    color: var(--accent); font-weight: 500;
  }
  .receipt-row.confirmed .v::before {
    content: ""; width: 6px; height: 6px; border-radius: 50%;
    background: var(--accent);
  }
  .receipt-rule { height: 1px; background: var(--border); margin: 2px 0; }
  .receipt-total { display: flex; justify-content: space-between; align-items: baseline; }
  .receipt-total .amt {
    font-size: 18px; font-weight: 500; letter-spacing: -0.02em;
    color: var(--text); font-family: var(--font-sans);
  }
  .receipt-total .amt small {
    color: var(--text3); font-size: 12px; margin-left: 4px;
  }

  @media (max-width: 900px) {
    .steps-grid { grid-template-columns: 1fr; gap: 16px; margin-top: 36px; }
  }

  /* ────────────────────────────────────────────────────────────
     What it covers — bento
     ──────────────────────────────────────────────────────────── */
  .covers-grid {
    display: grid; grid-template-columns: repeat(6, 1fr);
    grid-auto-rows: minmax(180px, auto);
    gap: 18px; margin-top: 56px;
  }
  .cover {
    grid-column: span 2;
    background: var(--bg-white);
    border: 1.5px solid var(--border);
    border-radius: var(--radius-card);
    padding: 26px;
    display: flex; flex-direction: column;
    transition: border-color .15s ease, box-shadow .15s ease;
    position: relative; overflow: hidden;
  }
  .cover:hover { border-color: var(--border2); box-shadow: var(--shadow-sm); }
  .cover.wide { grid-column: span 3; }
  .cover.tall { grid-row: span 2; }
  .cover .cover-eyebrow {
    font-family: var(--font-mono); font-size: 11px;
    color: var(--accent); letter-spacing: 0;
    margin-bottom: 10px;
  }
  .cover h3 {
    font-size: 20px; font-weight: 500; letter-spacing: -0.02em;
    color: var(--text); margin: 0 0 8px; text-wrap: balance;
  }
  .cover p {
    font-size: 14px; line-height: 1.5; color: var(--text2);
    margin: 0; text-wrap: pretty;
  }
  .cover .cover-foot { margin-top: auto; padding-top: 18px; }
  .cover-code {
    margin-top: 14px;
    background: var(--surface); border: 1px solid var(--border);
    border-radius: 12px;
    padding: 12px 14px;
    font-family: var(--font-mono); font-size: 12.5px;
    color: var(--text); line-height: 1.55;
    overflow: hidden;
  }
  .cover-code .ln { color: var(--text2); display: inline-block; min-width: 24px; }
  .cover-code .kw { color: var(--purple); }
  .cover-code .str { color: var(--accent); }
  .cover-code .com { color: var(--text3); }
  .cover-code .fn { color: var(--blue); }

  .enum-grid {
    margin-top: 14px;
    display: grid; grid-template-columns: repeat(3, 1fr);
    gap: 8px;
    font-family: var(--font-mono); font-size: 12.5px;
  }
  .enum-grid .e-cell {
    display: flex; justify-content: space-between;
    padding: 8px 11px;
    background: var(--surface); border: 1px solid var(--border);
    border-radius: 8px;
  }
  .enum-grid .e-cell .k { color: var(--text2); }
  .enum-grid .e-cell .v { color: var(--text); }

  .status-row {
    display: flex; flex-wrap: wrap; gap: 6px;
    margin-top: 14px;
  }
  .status-pill {
    display: inline-flex; align-items: center; gap: 6px;
    height: 26px; padding: 0 10px;
    border-radius: 999px;
    font-size: 12px; font-weight: 500; letter-spacing: -0.005em;
    font-family: var(--font-mono);
    background: var(--surface); border: 1px solid var(--border);
    color: var(--text);
  }
  .status-pill .num { color: var(--text3); font-weight: 400; }
  .status-pill.ok    { background: var(--green-soft); color: var(--accent); border-color: transparent; }
  .status-pill.warn  { background: var(--orange-soft); color: var(--orange); border-color: transparent; }
  .status-pill.fail  { background: var(--red-soft); color: var(--red); border-color: transparent; }

  .inline-code {
    font-family: var(--font-mono); font-size: 13px;
    background: var(--surface); padding: 1px 5px;
    border-radius: 5px; border: 1px solid var(--border);
  }

  @media (max-width: 1000px) {
    .covers-grid { grid-template-columns: repeat(4, 1fr); }
    .cover { grid-column: span 2; }
    .cover.wide { grid-column: span 4; }
    .cover.tall { grid-row: auto; }
  }
  @media (max-width: 640px) {
    .covers-grid { grid-template-columns: 1fr; grid-auto-rows: auto; margin-top: 36px; }
    .cover, .cover.wide { grid-column: span 1; }
  }

  /* ────────────────────────────────────────────────────────────
     Install — tabs
     ──────────────────────────────────────────────────────────── */
  .install-wrap {
    margin-top: 48px;
    background: var(--bg-white);
    border: 1.5px solid var(--border);
    border-radius: 22px;
    overflow: hidden;
  }
  .install-tabs {
    display: flex; align-items: center;
    border-bottom: 1px solid var(--border);
    background: var(--surface);
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }
  .install-tabs::-webkit-scrollbar { display: none; }
  .install-tab {
    padding: 16px 22px;
    font-size: 14px; font-weight: 500; letter-spacing: -0.01em;
    color: var(--text2); white-space: nowrap;
    border-bottom: 2px solid transparent;
    transition: color .15s ease, border-color .15s ease, background .15s ease;
  }
  .install-tab:hover { color: var(--text); }
  .install-tab.active {
    color: var(--text); border-bottom-color: var(--accent);
    background: var(--bg-white);
  }
  .install-body { padding: 28px 32px 32px; }
  .install-panel { display: none; }
  .install-panel.active { display: block; animation: fade-up .25s ease; }
  @keyframes fade-up { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: none; } }

  .install-panel h4 {
    font-size: 16px; font-weight: 500; color: var(--text);
    margin: 0 0 6px; letter-spacing: -0.01em;
  }
  .install-panel .desc {
    font-size: 14px; color: var(--text2); margin: 0 0 18px;
    line-height: 1.5; max-width: 620px; text-wrap: pretty;
  }
  .codeblock {
    background: var(--text);
    color: #d6efe2;
    border-radius: 14px;
    padding: 18px 22px;
    font-family: var(--font-mono); font-size: 13px;
    line-height: 1.65;
    overflow-x: auto;
    position: relative;
  }
  .codeblock .prompt { color: #6c8a80; user-select: none; }
  .codeblock .accent { color: #5BE39A; }
  .codeblock .com    { color: #6c8a80; }
  .codeblock pre { margin: 0; font: inherit; white-space: pre; }
  .codeblock .cb-copy {
    position: absolute; top: 12px; right: 12px;
    display: inline-flex; align-items: center; gap: 5px;
    height: 28px; padding: 0 10px;
    border-radius: 999px;
    background: rgba(255,255,255,0.07); color: #d6efe2;
    font-family: var(--font-sans);
    font-size: 12px; font-weight: 500;
    transition: background .15s ease;
  }
  .codeblock .cb-copy:hover { background: rgba(255,255,255,0.12); }
  .codeblock .cb-copy.copied { background: var(--accent); color: white; }
  .codeblock .cb-copy svg { width: 12px; height: 12px; }

  @media (max-width: 640px) {
    .install-body { padding: 22px; }
    .install-tab { padding: 14px 16px; font-size: 13px; }
    .codeblock { padding: 16px 14px; font-size: 12px; }
  }

  /* ────────────────────────────────────────────────────────────
     Safety section
     ──────────────────────────────────────────────────────────── */
  .safety {
    background: var(--surface);
    border-radius: 27px;
    padding: 56px;
    margin-top: 48px;
    display: grid; grid-template-columns: 1fr 1.1fr;
    gap: 56px; align-items: center;
  }
  .safety .safety-art {
    position: relative;
    height: 280px;
    border-radius: 18px;
    background: var(--bg-white);
    border: 1.5px solid var(--border);
    overflow: hidden;
    display: flex; align-items: center; justify-content: center;
    padding: 28px;
  }
  .safety .safety-art::before {
    content: ""; position: absolute; inset: 0;
    background:
      radial-gradient(60% 80% at 100% 0%, rgba(18,209,107,0.16), transparent 60%),
      radial-gradient(60% 80% at 0% 100%, rgba(18,209,107,0.10), transparent 60%);
    pointer-events: none;
  }
  .safety-art .lock {
    position: relative; z-index: 1;
    width: 100%; max-width: 320px;
    background: var(--text); color: #d6efe2;
    border-radius: 14px;
    padding: 18px;
    font-family: var(--font-mono); font-size: 12.5px;
    line-height: 1.7;
    box-shadow: var(--shadow);
    white-space: pre-wrap;
  }
  .safety-art .lock pre { margin: 0; font: inherit; white-space: pre-wrap; }
  .safety-art .lock .ok    { color: #5BE39A; }
  .safety-art .lock .bad   { color: #ff9999; text-decoration: line-through; opacity: .65; }
  .safety-art .lock .com   { color: #6c8a80; }
  .safety-list {
    list-style: none; padding: 0; margin: 22px 0 0;
    display: flex; flex-direction: column; gap: 14px;
  }
  .safety-list li {
    display: flex; gap: 14px; align-items: flex-start;
  }
  .safety-list li .ico {
    flex: 0 0 auto; width: 28px; height: 28px;
    border-radius: 8px; background: var(--bg-white);
    border: 1.5px solid var(--border);
    display: flex; align-items: center; justify-content: center;
    color: var(--accent);
  }
  .safety-list li .ico svg { width: 14px; height: 14px; }
  .safety-list li .lbl { font-size: 15px; line-height: 1.5; color: var(--text); }
  .safety-list li .lbl .k {
    display: block; font-weight: 500; color: var(--text); letter-spacing: -0.01em;
  }
  .safety-list li .lbl .v {
    display: block; font-size: 13.5px; color: var(--text2); margin-top: 2px;
  }
  .safety-list li .lbl .v code {
    font-family: var(--font-mono); font-size: 12.5px;
  }

  @media (max-width: 900px) {
    .safety { grid-template-columns: 1fr; padding: 36px; gap: 28px; }
