  .cta-strip::before {
    content: ""; position: absolute; inset: 0;
    background:
      radial-gradient(60% 90% at 100% 50%, rgba(255,255,255,0.18), transparent 60%);
    filter: url(#grain);
    pointer-events: none;
  }
  .cta-strip .cta-text { position: relative; z-index: 1; }
  .cta-strip .cta-text h2 {
    font-size: 38px; font-weight: 500; letter-spacing: -0.025em;
    margin: 0 0 8px; color: white; line-height: 1.05;
    text-wrap: balance;
  }
  .cta-strip .cta-text p {
    font-size: 16px; opacity: .88; color: white; margin: 0;
    max-width: 480px;
  }
  .cta-strip .cta-actions {
    position: relative; z-index: 1;
    display: flex; gap: 12px; align-items: center; flex-shrink: 0;
  }
  .btn-on-green {
    display: inline-flex; align-items: center; gap: 6px;
    height: var(--btn-h); padding: 0 22px;
    border-radius: var(--radius-btn);
    background: white; color: var(--accent);
    font-size: 15px; font-weight: 500; letter-spacing: -0.01em;
    transition: background .15s ease;
  }
  .btn-on-green:hover { background: #f4fffa; color: var(--accent2); }
  .btn-on-green-ghost {
    display: inline-flex; align-items: center; gap: 6px;
    height: var(--btn-h); padding: 0 22px;
    border-radius: var(--radius-btn);
    background: rgba(255,255,255,0.12); color: white;
    border: 1px solid rgba(255,255,255,0.35);
    font-size: 15px; font-weight: 500; letter-spacing: -0.01em;
    transition: background .15s ease;
  }
  .btn-on-green-ghost:hover { background: rgba(255,255,255,0.2); color: white; }

  @media (max-width: 800px) {
    .cta-strip { flex-direction: column; align-items: flex-start; padding: 36px; }
    .cta-strip .cta-text h2 { font-size: 30px; }
    .cta-strip .cta-actions { width: 100%; flex-wrap: wrap; }
  }

  /* ────────────────────────────────────────────────────────────
     Footer
     ──────────────────────────────────────────────────────────── */
  footer.foot {
    padding: 36px 0;
    border-top: 1px solid var(--border);
    color: var(--text2);
    font-size: 13px;
  }
  .foot-inner {
    display: flex; align-items: center; justify-content: space-between;
    gap: 16px; flex-wrap: wrap;
  }
  .foot-brand { display: flex; align-items: center; gap: 10px; }
  .foot-brand img { height: 20px; }
  .foot-brand .pipe { width: 1px; height: 16px; background: var(--border2); }
  .foot-brand .sub { font-size: 13px; font-weight: 500; color: var(--text2); }
  .foot-meta {
    display: inline-flex; align-items: center; gap: 12px;
    color: var(--text3); font-size: 12.5px;
