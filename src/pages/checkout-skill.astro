  /* ────────────────────────────────────────────────────────────
     CTA strip
     ──────────────────────────────────────────────────────────── */
  .cta-strip {
    position: relative;
    background: var(--accent);
    color: white;
    border-radius: 27px;
    padding: 56px 56px;
    overflow: hidden;
    display: flex; align-items: center; justify-content: space-between;
    gap: 28px;
    box-shadow: 0 12px 60px rgba(0,152,89,0.25);
